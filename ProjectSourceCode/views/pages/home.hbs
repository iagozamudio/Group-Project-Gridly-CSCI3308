
{{>navbar}}
<div class="container py-5">

    <!-- Welcome -->
    <div class="mb-5 text-center">
        <img src="/img/logo.png" alt="Gridly logo" class="img-fluid" style="max-width: 400px;">
    </div>

    <main class="d-flex justify-content-center gap-5">

        <!-- Left section -->
        <div class="d-flex flex-column align-items-center gap-3">
            <h2>Welcome, {{user.username}} 👋</h2>
            <!-- Play Now button -->
            <a href="/singleplayer" class="btn btn-success btn-lg mt-2" style="min-width: 200px;">
                👤 Single Player
            </a>
            <a href="/twoplayer" class="btn btn-success btn-lg mt-2" style="min-width: 200px;">
                👥 Two Player
            </a>
        </div>

        <!-- Right section (user stats card) -->
        <div class="d-flex flex-column align-items-center">

           <div class="card shadow p-3 text-white" style="width: 300px; height: 120px; background-color: #3b3b3b; border-radius: 12px;">

        <div class="d-flex flex-column gap-2" style="font-size: 20px;">
            <span>🔥 5 day streak</span>
            <span>🏆 1380 elo</span>
        </div>

    </div>

        </div>

    </main>

</div>
<script id="user-data" type="application/json">
    {{{json user}}}
</script>

