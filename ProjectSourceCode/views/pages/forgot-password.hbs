<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Forgot Password</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="/ProjectSourceCode/css/loginRegistration.css">
</head>
<body>

    <div class="d-flex flex-column align-items-center py-4">
        <!-- Logo -->
        <div class="logo-wrapper">
            <img src="/ProjectSourceCode/img/logo.png" alt="Logo" class="img-fluid">
        </div>

        <!-- Card -->
        <div class="card shadow" style="width: 400px;">
            <div class="card-body">

                <!-- Step 1: Enter username -->
                <div id="step-1">
                    <p class="text-center mb-3" style="color:#ccc; font-size:0.95rem;">
                        Enter your username to retrieve your security question.
                    </p>
                    <form action="/forgot-password" method="POST">
                        <div class="mb-3">
                            <input type="text" id="username" name="username" class="form-control" placeholder="Username" required>
                            <label for="username" class="form-label mt-1">Username</label>
                        </div>
                        <div class="d-grid mb-2">
                            <button type="submit" class="btn btn-primary">Continue</button>
                        </div>
                    </form>
                </div>

            </div>
        </div>

        <!-- Back to login -->
        <div class="mt-3">
            <a href="/ProjectSourceCode/views/pages/login.hbs" style="color:#aaa; font-size:0.9rem; text-decoration:none;">
                &larr; Back to Log In
            </a>
        </div>
    </div>

    <!-- Mission statement -->
    <footer class="text-center py-3">
        <p class="mb-0">An engaging experience for crossword enthusiasts who want to test themselves and compete against others.</p>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
