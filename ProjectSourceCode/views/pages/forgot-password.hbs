<div class="d-flex flex-column align-items-center py-4">

  <!-- Logo -->
  <div class="logo-wrapper">
    <img src="/img/logo.png" alt="Gridly Logo" class="img-fluid">
  </div>

  <!-- Card -->
  <div class="card shadow" style="width: 400px;">
    <div class="card-body">

      {{> message}}

      {{!-- ─────────────────────────────────────────── --}}
      {{!-- STEP 3: Choose a new password               --}}
      {{!-- Server passes: resetReady=true, username    --}}
      {{!-- ─────────────────────────────────────────── --}}
      {{#if resetReady}}
        <p class="text-center mb-3" style="color:#ccc; font-size:0.95rem;">
          Choose a new password for <strong>{{ username }}</strong>.
        </p>
        <form action="/reset-password" method="POST">

          {{!-- Hidden field carries the username to the POST handler --}}
          <input type="hidden" name="username" value="{{ username }}">

          <div class="mb-3">
            <input type="password" id="newPassword" name="newPassword"
                   class="form-control" placeholder="New password" required>
            <label for="newPassword" class="form-label mt-1">New password</label>
          </div>
          <div class="mb-3">
            <input type="password" id="confirmPassword" name="confirmPassword"
                   class="form-control" placeholder="Confirm new password" required>
            <label for="confirmPassword" class="form-label mt-1">Confirm new password</label>
          </div>
          <div class="d-grid mb-2">
            <button type="submit" class="btn btn-success">Reset Password</button>
          </div>
        </form>

      {{!-- ─────────────────────────────────────────── --}}
      {{!-- STEP 2: Answer the security question        --}}
      {{!-- Server passes: question, username           --}}
      {{!-- ─────────────────────────────────────────── --}}
      {{else if question}}
        <p class="text-center mb-3" style="color:#ccc; font-size:0.95rem;">
          Answer your security question to continue.
        </p>
        <form action="/verify-answer" method="POST">

          {{!-- Hidden fields carry username + question through to the next POST --}}
          <input type="hidden" name="username" value="{{ username }}">
          <input type="hidden" name="question" value="{{ question }}">

          <div class="mb-3">
            <label class="form-label" style="color:#ccc;">{{ questionText }}</label>
          </div>
          <div class="mb-3">
            <input type="text" id="securityAnswer" name="securityAnswer"
                   class="form-control" placeholder="Your answer" required>
            <label for="securityAnswer" class="form-label mt-1">Your answer</label>
          </div>
          <div class="d-grid mb-2">
            <button type="submit" class="btn btn-primary">Verify</button>
          </div>
        </form>

      {{!-- ─────────────────────────────────────────── --}}
      {{!-- STEP 1: Enter username (default view)       --}}
      {{!-- Server passes nothing special               --}}
      {{!-- ─────────────────────────────────────────── --}}
      {{else}}
        <p class="text-center mb-3" style="color:#ccc; font-size:0.95rem;">
          Enter your username to retrieve your security question.
        </p>
        <form action="/forgot-password" method="POST">
          <div class="mb-3">
            <input type="text" id="username" name="username"
                   class="form-control" placeholder="Username" required>
            <label for="username" class="form-label mt-1">Username</label>
          </div>
          <div class="d-grid mb-2">
            <button type="submit" class="btn btn-primary">Continue</button>
          </div>
        </form>
      {{/if}}

    </div>
  </div>

  <!-- Back to login -->
  <div class="mt-3">
    <a href="/login" style="color:#aaa; font-size:0.9rem; text-decoration:none;">
      &larr; Back to Log In
    </a>
  </div>

</div>
