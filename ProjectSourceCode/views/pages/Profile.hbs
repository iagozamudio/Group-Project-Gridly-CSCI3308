{{>navbar}}
<div class="container-fluid">

  <div class="position-relative">
    <div style="
      background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.8)),
                  url('https://media.istockphoto.com/id/118393737/photo/crossword-background.jpg?s=1024x1024&w=is&k=20&c=OJZeiB_abADBcf7WEOX-OuMlzGe4pdC4SFAP79e-95s=');
      height: 100px;
      background-size: cover;
      background-position: center;
    ">
    </div>

    <div class="position-absolute d-flex align-items-end"
         style="bottom:-60px; left:30px; height:125px;">

      <img src="{{#if user.profile_image}}{{user.profile_image}}{{else}}https://cdn.pixabay.com/photo/2017/06/13/12/54/profile-2398783_1280.png{{/if}}"
           class="rounded-circle border border-light"
           style="width:150px; height:150px; object-fit: cover;">

      <div class="ms-4">
        <h1 class="mb-0 fs-1">{{#if user.display_name}}{{user.display_name}}{{else}}{{user.username}}{{/if}}</h1>
        <p class="text-secondary fs-4 mb-2">@{{user.username}}</p>

        <div class="d-flex gap-5">
          <div class="d-flex gap-5 flex-wrap">
            <div>
              <h5 class="fs-3">{{stats.totalScore}}</h5>
              <p class="text-secondary fs-5 mb-0">Points Earned</p>
            </div>

            <div>
              <h5 class="fs-3">#{{ranks.singleScoreRank}}</h5>
              <p class="text-secondary fs-5 mb-0">Score Rank</p>
            </div>

            <div>
              <h5 class="fs-3">#{{ranks.fastestTimeRank}}</h5>
              <p class="text-secondary fs-5 mb-0">Fastest Time Rank</p>
            </div>

            <div>
              <h5 class="fs-3">#{{ranks.twoPlayerRank}}</h5>
              <p class="text-secondary fs-5 mb-0">Two-Player Rank</p>
            </div>
          </div>
        </div>
      </div>

    </div>
  </div>

  <div style="height:120px;"></div>

  <div class="row p-3 mt-3">

    <div class="col-md-6 border-end border-secondary">
      <h5 class="fs-3 text-center"> 👾 Game History 👾</h5>
      <div class="border border-secondary rounded p-3 mt-2" style="overflow-y: auto;">
        {{#if gameHistory.length}}

          {{#each gameHistory}}
            <div class="border-bottom pb-2 mb-2">
              <div><strong>{{game_type}}</strong></div>
              <div>Score: {{score}}</div>
              <div>Time: {{time_seconds}} sec</div>
              {{#if completion}}
                <div>Completion: {{completion}}</div>
              {{/if}}
              {{#if result}}
                <div>Result: {{result}}</div>
              {{/if}}
              <div>{{completed_at}}</div>
            </div>
          {{/each}}

        {{else}}
          <p class="text-secondary mb-0"> 🥲 No games played yet 😭.</p>
        {{/if}}
      </div>
    </div>

    <div class="col-md-6">
      <h5 class="fs-3 text-center"> 🔥 Stats 🔥</h5>
      <div class="border border-secondary rounded p-3 mt-2">
        <div class="border-bottom pb-2 mb-2">Total Games Played: {{stats.totalGames}}</div>
        <div class="border-bottom pb-2 mb-2">Best Single Score: {{stats.bestSingleScore}}</div>
        <div class="border-bottom pb-2 mb-2">Average Completion: {{stats.avgCompletion}}%</div>
        <div class="border-bottom pb-2 mb-2">Wins: {{stats.wins}}</div>
        <div>Win Rate: {{stats.winRate}}%</div>
      </div>
    </div>

  </div>

</div>
